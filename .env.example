# Copy this file to .env and fill in your real key.
# Get a free Groq API key at https://console.groq.com/keys

GROQ_API_KEY=your_groq_api_key_here

# Optional — override the model used for all generations.
# Check https://console.groq.com/docs/models for current available model names.
GROQ_MODEL=llama-3.3-70b-versatile

# Optional — port for the local Express API server.
PORT=8787
